apiVersion: 1
datasources:
  - name: InfluxDB-Fuel
    type: influxdb
    access: proxy
    url: http://localhost:8086
    isDefault: true
    jsonData:
      version: Flux
      organization: "{{ influxdb_org }}"
      defaultBucket: "{{ influxdb_bucket_fuel }}"
      tlsSkipVerify: true
    secureJsonData:
      token: "{{ influxdb_admin_token }}"

  - name: Postgres-FuelAudit
    type: postgres
    access: proxy
    url: "{{ fuel_db_ip }}:5432"
    database: "{{ postgres_db_fuel }}"
    user: "{{ postgres_user_fuel_ro }}"
    jsonData:
      sslmode: disable
      postgresVersion: 16
      timescaledb: true
    secureJsonData:
      password: "{{ postgres_password_fuel_rw }}"
