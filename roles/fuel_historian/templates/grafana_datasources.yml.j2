apiVersion: 1
datasources:
  # Grafana runs in its own container. localhost:8086 from inside the
  # container is Grafana's loopback, not InfluxDB (which lives in a
  # separate container bound to fuel_hist_ip:8086 via docker publish).
  # Use the prod NIC so Grafana's InfluxDB queries route out through
  # docker's default bridge -> host -> published-port back to InfluxDB.
  # Same pattern as Telegraf. Alternative would be to join both
  # containers to a docker network and use container-name DNS, but
  # this keeps every service-to-service call in the fuel farm addressed
  # by the same prod-NIC IP scheme.
  - name: InfluxDB-Fuel
    type: influxdb
    access: proxy
    url: http://{{ fuel_hist_ip }}:8086
    isDefault: true
    jsonData:
      version: Flux
      organization: "{{ influxdb_org }}"
      defaultBucket: "{{ influxdb_bucket_fuel }}"
      tlsSkipVerify: true
    secureJsonData:
      token: "{{ influxdb_admin_token }}"

  - name: Postgres-FuelAudit
    type: postgres
    access: proxy
    url: "{{ fuel_db_ip }}:5432"
    database: "{{ postgres_db_fuel }}"
    user: "{{ postgres_user_fuel_ro }}"
    jsonData:
      sslmode: disable
      postgresVersion: 16
      timescaledb: true
    secureJsonData:
      password: "{{ postgres_password_fuel_rw }}"
