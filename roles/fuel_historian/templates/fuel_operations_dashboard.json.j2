      "type": "table",
      "title": "Fuel loaded per truck (last 24h)",
      "datasource": "Postgres-FuelAudit",
      "targets": [{
        "rawQuery": true,
        "rawSql": "SELECT truck_id, SUM(gallons)::int AS gal_loaded, COUNT(*) AS loads FROM load_txn WHERE start_ts > now() - INTERVAL '24 hours' GROUP BY truck_id ORDER BY gal_loaded DESC;",
        "format": "table",
        "refId": "A"
      }],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 21 }
    },
    {
      "type": "table",
      "title": "Aircraft deliveries (last 24h)",
