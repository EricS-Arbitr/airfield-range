      "datasource": "Postgres-FuelAudit",
      "targets": [{
        "rawQuery": true,
        "rawSql": "SELECT DISTINCT ON (tank_id) tank_id, level_gal, temp_f, ts FROM tank_level_snap ORDER BY tank_id, ts DESC;",
