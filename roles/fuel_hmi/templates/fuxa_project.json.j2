{#
  fuxa_project.json.j2 -- FUXA v1.13 project file for the fuel farm HMI.

  Schema learned from frangoteam/FUXA client/dist/assets/project.demo.fuxap
  (fetched 2026-07-17) and from server/runtime/devices/modbus/index.js:

  Top-level keys: {version, projectFile, server, devices, hmi, charts}.
  Devices are keyed by UUID, not name. Each tag has:
    - address: 1-based Modbus register (FUXA subtracts 1 internally)
    - memaddress: NUMERIC constant
        0      = Coils
        100000 = Discrete Inputs
        300000 = Input Registers
        400000 = Holding Registers
    - type: data type string ("Bool", "Int16", ...)
    - divisor: read-side scale (raw / divisor = engineering units)

  Widgets in items{} reference tags via variableId of form
  "DeviceName^~^TagName".

  The two SVG documents are authored as separate files under files/
  and inlined by Jinja's lookup filter (with |tojson escaping) into
  the view's svgcontent string.
#}
{
  "version": "1.00",
  "projectFile": "fuel_farm.fuxap",
  "server": {
    "id": "0",
    "name": "FuxaServer",
    "type": "FuxaServer",
    "property": { "address": "0.0.0.0" }
  },
  "devices": {
    "{{ fuxa_plc_device_uuid }}": {
      "id": "{{ fuxa_plc_device_uuid }}",
      "name": "PLC-FuelFarm",
      "type": "ModbusTCP",
      "enabled": true,
      "polling": 1000,
      "property": {
        "address": "{{ fuel_plc_ip }}",
        "port": {{ fuel_modbus_port }},
        "slaveid": 1
      },
      "tags": {
{% set tag_rows = [] %}
{# FUXA driver bug workaround: for coils, memaddress must be the STRING
   "000000" (six zeros), not the numeric 0. The main tag loop keys memory
   with formatAddress(memaddress, token) = `${token}-${memaddress}`. For
   numeric 0 that yields "0-0", but the fragmented-loop's getMemoryAddress
   returns formatAddress('000000', token) = "0-000000" for coils
   specifically (driver hardcodes the string). Mismatched keys ->
   memory[lookup] undefined -> "Cannot read properties of undefined
   (reading 'Items')" fires once per coil. Using the string "000000"
   makes both code paths agree. DIs/IRs/HRs don't hit this because their
   constants (100000/300000/400000) go through formatAddress directly
   both times. #}
{% for c in fuel_modbus_coils %}
{%   set _ = tag_rows.append('"' ~ c.tag ~ '": {"id":"' ~ c.tag ~ '","name":"' ~ c.tag ~ '","type":"Bool","address":' ~ (c.addr + 1) ~ ',"memaddress":"000000","daq":{"enabled":true,"changed":true,"interval":60,"restored":false}}') %}
{% endfor %}
{# OpenPLC's slave-device polling doesn't overlay onto the ST program's
   %IX0.0/%IW0 addresses. Instead it lands at %IX100.0+ (= Modbus DI 800+)
   and %IW100+ (= Modbus IR 100+). See webserver.py:895 -- the "100 + counter"
   offset is hard-coded. So even though fuel_farm.st declares
   P201_RUN_STS AT %IX0.0 and T101_LEVEL AT %IW0, the values fuelsim is
   polled for actually live at IX100.0 / IW100. FUXA needs to poll THOSE
   addresses to see the live data.

   Group vars fuel_modbus_discrete_inputs / _input_registers give the
   "logical" address (0-10 / 0-10) matching the .st's %IX0.0 / %IW0 layout.
   Here we translate to the wire-level Modbus address by adding the
   slave-mapping base offset (+800 for DIs, +100 for IRs) and then +1 for
   FUXA's 1-based address scheme. #}
{% for d in fuel_modbus_discrete_inputs %}
{%   set _ = tag_rows.append('"' ~ d.tag ~ '": {"id":"' ~ d.tag ~ '","name":"' ~ d.tag ~ '","type":"Bool","address":' ~ (d.addr + 800 + 1) ~ ',"memaddress":100000,"daq":{"enabled":true,"changed":true,"interval":60,"restored":false}}') %}
{% endfor %}
{% for r in fuel_modbus_input_registers %}
{%   set divisor = (1.0 / r.scale) | round(0, 'floor') | int %}
{%   set _ = tag_rows.append('"' ~ r.tag ~ '": {"id":"' ~ r.tag ~ '","name":"' ~ r.tag ~ '","type":"Int16","address":' ~ (r.addr + 100 + 1) ~ ',"memaddress":300000,"divisor":' ~ divisor ~ ',"daq":{"enabled":true,"changed":true,"interval":10,"restored":false}}') %}
{% endfor %}
{% for h in fuel_modbus_holding_registers %}
{%   set _ = tag_rows.append('"' ~ h.tag ~ '": {"id":"' ~ h.tag ~ '","name":"' ~ h.tag ~ '","type":"Int16","address":' ~ (h.addr + 1) ~ ',"memaddress":400000,"daq":{"enabled":true,"changed":true,"interval":10,"restored":false}}') %}
{% endfor %}
        {{ tag_rows | join(',\n        ') }}
      }
    }
  },
  "hmi": {
    "views": [
      {
        "id": "v_process_overview",
        "name": "Process Overview",
        "profile": { "width": 1280, "height": 720, "bkcolor": "#f5f5f5" },
        "variables": {},
        "svgcontent": {{ lookup('file', 'svg_process_overview.svg') | tojson }},
        "items": {
{% set items_overview = [] %}
{#   Bind each _txt SVG text element to the corresponding Modbus tag via svg-ext-value #}
{% for pair in [
    ('T101_LEVEL_txt', 'T101_LEVEL', 'T-101 Level %'),
    ('T102_LEVEL_txt', 'T102_LEVEL', 'T-102 Level %'),
    ('T103_LEVEL_txt', 'T103_LEVEL', 'T-103 Level %'),
    ('T101_TEMP_txt', 'T101_TEMP', 'T-101 Temp F'),
    ('HEADER_PRESS_txt', 'HEADER_PRESS', 'Header Pressure psi'),
    ('LR1_ACTIVE_TRUCK_txt', 'LR1_ACTIVE_TRUCK', 'LR-1 Active Truck'),
    ('LR1_SRC_TANK_txt', 'LR1_SRC_TANK', 'LR-1 Source Tank'),
    ('LR1_PRESET_GAL_txt', 'LR1_PRESET_GAL', 'LR-1 Preset Gal'),
    ('LR1_FLOW_txt', 'LR1_FLOW', 'LR-1 Flow gpm'),
    ('LR2_ACTIVE_TRUCK_txt', 'LR2_ACTIVE_TRUCK', 'LR-2 Active Truck'),
    ('LR2_SRC_TANK_txt', 'LR2_SRC_TANK', 'LR-2 Source Tank'),
    ('LR2_PRESET_GAL_txt', 'LR2_PRESET_GAL', 'LR-2 Preset Gal'),
    ('LR2_FLOW_txt', 'LR2_FLOW', 'LR-2 Flow gpm'),
] %}
{%   set _ = items_overview.append('"' ~ pair[0] ~ '": {"id":"' ~ pair[0] ~ '","type":"svg-ext-shapes-text","name":"' ~ pair[2] ~ '","property":{"variable":"' ~ pair[1] ~ '","variableSrc":"PLC-FuelFarm","variableId":"PLC-FuelFarm^~^' ~ pair[1] ~ '","events":[],"actions":[],"ranges":[]},"label":"Value"}') %}
{% endfor %}
{# Status dots -- FUXA can flip fill color via svg-ext-shape actions on boolean tags #}
{% for pair in [
    ('P201_RUN_STS_dot', 'P201_RUN_STS'),
    ('P202_RUN_STS_dot', 'P202_RUN_STS'),
    ('LR1_GROUND_OK_dot', 'LR1_GROUND_OK'),
    ('LR1_DEADMAN_dot', 'LR1_DEADMAN'),
    ('LR1_OVERFILL_dot', 'LR1_OVERFILL'),
    ('P201_RUN_CMD_dot', 'P201_RUN_CMD'),
    ('LR2_GROUND_OK_dot', 'LR2_GROUND_OK'),
    ('LR2_DEADMAN_dot', 'LR2_DEADMAN'),
    ('LR2_OVERFILL_dot', 'LR2_OVERFILL'),
    ('P202_RUN_CMD_dot', 'P202_RUN_CMD'),
] %}
{%   set _ = items_overview.append('"' ~ pair[0] ~ '": {"id":"' ~ pair[0] ~ '","type":"svg-ext-shapes-circle","name":"' ~ pair[1] ~ '","property":{"variable":"' ~ pair[1] ~ '","variableSrc":"PLC-FuelFarm","variableId":"PLC-FuelFarm^~^' ~ pair[1] ~ '","events":[],"actions":[{"type":"clockwise","range":{"min":1,"max":1},"color":"#2c8f3f"}],"ranges":[]},"label":"Shape"}') %}
{% endfor %}
{# ESD banner turns red when ESD_ACTIVE=1 #}
{% set _ = items_overview.append('"esd_banner_rect": {"id":"esd_banner_rect","type":"svg-ext-shapes-rect","name":"ESD Banner","property":{"variable":"ESD_ACTIVE","variableSrc":"PLC-FuelFarm","variableId":"PLC-FuelFarm^~^ESD_ACTIVE","events":[],"actions":[{"type":"clockwise","range":{"min":1,"max":1},"color":"#c62828"}],"ranges":[]},"label":"Shape"}') %}
{# Nav button to Rack Detail view -- svg-ext-shapes-rect matches the <rect>
   element's auto-derived type; the click event still fires via property.events. #}
{% set _ = items_overview.append('"nav_rack_detail_btn": {"id":"nav_rack_detail_btn","type":"svg-ext-shapes-rect","name":"Nav to Detail","property":{"events":[{"type":"click","action":"onSetView","actparam":"v_rack_detail"}],"actions":[],"ranges":[]},"label":"Button"}') %}
          {{ items_overview | join(',\n          ') }}
        }
      },
      {
        "id": "v_rack_detail",
        "name": "Loading Rack Detail",
        "profile": { "width": 1280, "height": 720, "bkcolor": "#f5f5f5" },
        "variables": {},
        "svgcontent": {{ lookup('file', 'svg_rack_detail.svg') | tojson }},
        "items": {
{% set items_detail = [] %}
{% for pair in [
    ('LR1D_ACTIVE_TRUCK_txt', 'LR1_ACTIVE_TRUCK', 'LR-1 Active Truck'),
    ('LR1D_SRC_TANK_txt', 'LR1_SRC_TANK', 'LR-1 Source Tank'),
    ('LR1D_PRESET_GAL_txt', 'LR1_PRESET_GAL', 'LR-1 Preset Gal'),
    ('LR1D_METER_txt', 'LR1_METER_LO', 'LR-1 Meter (low word only)'),
    ('LR1D_FLOW_txt', 'LR1_FLOW', 'LR-1 Flow gpm'),
    ('LR2D_ACTIVE_TRUCK_txt', 'LR2_ACTIVE_TRUCK', 'LR-2 Active Truck'),
    ('LR2D_SRC_TANK_txt', 'LR2_SRC_TANK', 'LR-2 Source Tank'),
    ('LR2D_PRESET_GAL_txt', 'LR2_PRESET_GAL', 'LR-2 Preset Gal'),
    ('LR2D_METER_txt', 'LR2_METER_LO', 'LR-2 Meter (low word only)'),
    ('LR2D_FLOW_txt', 'LR2_FLOW', 'LR-2 Flow gpm'),
] %}
{%   set _ = items_detail.append('"' ~ pair[0] ~ '": {"id":"' ~ pair[0] ~ '","type":"svg-ext-shapes-text","name":"' ~ pair[2] ~ '","property":{"variable":"' ~ pair[1] ~ '","variableSrc":"PLC-FuelFarm","variableId":"PLC-FuelFarm^~^' ~ pair[1] ~ '","events":[],"actions":[],"ranges":[]},"label":"Value"}') %}
{% endfor %}
{% for pair in [
    ('LR1D_GROUND_OK_dot', 'LR1_GROUND_OK'),
    ('LR1D_DEADMAN_dot', 'LR1_DEADMAN'),
    ('LR1D_OVERFILL_dot', 'LR1_OVERFILL'),
    ('LR1D_LOAD_VLV_dot', 'LR1_LOAD_VLV'),
    ('LR1D_ESD_dot', 'ESD_ACTIVE'),
    ('LR2D_GROUND_OK_dot', 'LR2_GROUND_OK'),
    ('LR2D_DEADMAN_dot', 'LR2_DEADMAN'),
    ('LR2D_OVERFILL_dot', 'LR2_OVERFILL'),
    ('LR2D_LOAD_VLV_dot', 'LR2_LOAD_VLV'),
    ('LR2D_ESD_dot', 'ESD_ACTIVE'),
] %}
{%   set color = '#c62828' if 'OVERFILL' in pair[1] or 'ESD' in pair[1] else '#2c8f3f' %}
{%   set _ = items_detail.append('"' ~ pair[0] ~ '": {"id":"' ~ pair[0] ~ '","type":"svg-ext-shapes-circle","name":"' ~ pair[1] ~ '","property":{"variable":"' ~ pair[1] ~ '","variableSrc":"PLC-FuelFarm","variableId":"PLC-FuelFarm^~^' ~ pair[1] ~ '","events":[],"actions":[{"type":"clockwise","range":{"min":1,"max":1},"color":"' ~ color ~ '"}],"ranges":[]},"label":"Shape"}') %}
{% endfor %}
{% set _ = items_detail.append('"navD_overview_btn": {"id":"navD_overview_btn","type":"svg-ext-shapes-rect","name":"Nav to Overview","property":{"events":[{"type":"click","action":"onSetView","actparam":"v_process_overview"}],"actions":[],"ranges":[]},"label":"Button"}') %}
          {{ items_detail | join(',\n          ') }}
        }
      }
    ],
    "variables": {}
  },
  "charts": []
}
